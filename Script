local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

local DataRemote = ReplicatedStorage
	:WaitForChild("NetworkingContainer")
	:WaitForChild("DataRemote")

local PLACE_LOBBY = 13775256536
local PLACE_TOILET_HQ = 93712201161812

local UNITS = {
	"Laser Cameraman Car",
	"Speakerman"
}

local PLACE_POS = Vector3.new(
	71.96743774414062,
	16.776081085205078,
	172.82130432128906
)

local placed = false
local placedUnit = nil

print("SCRIPT STARTED")

-- =========================
-- LOBBY REMOTE
-- =========================

local function FireLobbyRemote()

	local oldPlace = game.PlaceId

	local args150 = {
		{
			{
				"\226\129\130\150"
			}
		}
	}

	DataRemote:FireServer(unpack(args150))

	local start = tick()

	while tick() - start < 5 do

		task.wait(0.5)

		if game.PlaceId ~= oldPlace then
			print("Teleport Success With 150")
			return
		end
	end

	if game.PlaceId == oldPlace then

		local args148 = {
			{
				{
					"\226\129\130\148"
				}
			}
		}

		print("Fallback To 148")

		DataRemote:FireServer(unpack(args148))
	end
end

-- =========================
-- TELEPORT
-- =========================

local function SmartTeleport()

	local char =
		LocalPlayer.Character
		or LocalPlayer.CharacterAdded:Wait()

	local hrp =
		char:WaitForChild("HumanoidRootPart")

	local Lifts = workspace:FindFirstChild("Lifts")

	if not Lifts then
		return
	end

	local list = Lifts:GetChildren()

	local move = false

	pcall(function()

		local txt =
			list[15].Base.StatusGui.PlayersCount.Text

		print("Players:", txt)

		if txt == "2/5" then
			move = true
		end
	end)

	local targets

	if move then

		targets = {
			list[16],
			list[15],
			list[12]
		}

	else

		targets = {
			Lifts:FindFirstChild("ToiletHQ")
		}
	end

	for _, v in ipairs(targets) do

		if v and v:FindFirstChild("Base") then

			hrp.CFrame =
				v.Base.CFrame + Vector3.new(0,5,0)

			print("TP:", v.Name)

			task.wait(1)
		end
	end
end

-- =========================
-- PLACE
-- =========================

local function PlaceUnit(name)

	local args = {
		{
			{
				"\226\129\130\022",
				name,
				PLACE_POS,
				1
			}
		}
	}

	DataRemote:FireServer(unpack(args))
end

-- =========================
-- UPGRADE
-- =========================

local function Upgrade(unit)

	local args = {
		{
			{
				"\226\129\130#",
				unit
			}
		}
	}

	DataRemote:FireServer(unpack(args))
end

